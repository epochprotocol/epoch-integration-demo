# Required: wallet that holds testnet tokens on Sepolia
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Epoch allocator API (testnet)
EPOCH_API_BASE_URL=https://testnet-dev.epochprotocol.xyz

# Optional: override Sepolia RPC (defaults to https://ethereum-sepolia-rpc.publicnode.com)
# Avoid browser-restricted Ankr keys in Node.js — they return "Origin not allowed".
# SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Swap parameters (defaults shown)
# INPUT_TOKEN_SYMBOL=USDC
# OUTPUT_TOKEN_SYMBOL=PENGU
# INPUT_AMOUNT=1
# SLIPPAGE_BPS=100
